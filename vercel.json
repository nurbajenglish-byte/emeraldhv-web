{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/tour", "dest": "/public/tour.html" },
    { "src": "/competitions", "dest": "/public/competitions.html" },
    { "src": "/competitions/success", "dest": "/public/success.html" },
    { "src": "/competitions/cancel", "dest": "/public/competitions.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
